{
  "name": "@liflig/repo-metrics-repo-collector",
  "version": "0.0.0-development",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -noEmit && rm -rf dist && bun build src/lambda.ts --bundle --target=node --format=cjs --outfile=dist/index.js",
    "test": "vitest --run",
    "collect-locally": "bun run src/collect-locally.ts",
    "aggregate-locally": "bun run src/aggregate-locally.ts",
    "report-locally": "bun run src/report-locally.ts",
    "serve": "bun run src/serve-data.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudfront": "3.1091.0",
    "@aws-sdk/client-s3": "3.1091.0",
    "@aws-sdk/client-secrets-manager": "3.1091.0",
    "@octokit/types": "16.0.0",
    "@slack/types": "3.0.0",
    "@types/aws-lambda": "8.10.162",
    "@types/bun": "^1.3.10",
    "@types/js-yaml": "4.0.9",
    "@types/lodash-es": "4.17.12",
    "@types/node": "24.13.3",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@js-temporal/polyfill": "0.5.1",
    "@liflig/repo-metrics-repo-collector-types": "workspace:*",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "ajv": "8.20.0",
    "axios": "1.18.1",
    "date-holidays": "3.33.0",
    "js-yaml": "5.2.1",
    "lodash-es": "4.18.1",
    "p-limit": "^7.3.0"
  }
}
