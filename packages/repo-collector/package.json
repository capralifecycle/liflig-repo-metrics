{
  "name": "@liflig/repo-metrics-repo-collector",
  "version": "0.0.0-development",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -noEmit && rm -rf dist && bun build src/lambda.ts --bundle --target=node --format=cjs --outfile=dist/index.js",
    "test": "vitest --run",
    "collect-locally": "bun run src/collect-locally.ts",
    "aggregate-locally": "bun run src/aggregate-locally.ts",
    "report-locally": "bun run src/report-locally.ts",
    "serve": "bun run src/serve-data.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudfront": "3.1032.0",
    "@aws-sdk/client-s3": "3.1032.0",
    "@aws-sdk/client-secrets-manager": "3.1032.0",
    "@octokit/types": "16.0.0",
    "@types/aws-lambda": "8.10.161",
    "@types/bun": "^1.3.10",
    "@types/js-yaml": "4.0.9",
    "@types/lodash-es": "4.17.12",
    "@types/node": "24.12.2",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  },
  "dependencies": {
    "@js-temporal/polyfill": "0.5.1",
    "@liflig/repo-metrics-repo-collector-types": "0.0.0-development",
    "@octokit/rest": "^22.0.1",
    "ajv": "8.18.0",
    "axios": "1.15.1",
    "date-holidays": "3.27.0",
    "js-yaml": "4.1.1",
    "lodash-es": "4.18.1",
    "p-limit": "^7.3.0"
  }
}
